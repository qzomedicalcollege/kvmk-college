---
import { useTranslations } from '../i18n/utils';

const { lang } = Astro.props;
const t = useTranslations(lang);
---

<!-- PAGE HERO -->
<section class="section-padding" style="background: linear-gradient(135deg, rgba(var(--color-primary-rgb), 0.04), rgba(var(--color-secondary-rgb), 0.04)); padding-top: 140px; padding-bottom: 60px;">
  <div class="container text-center">
    <h1 class="section-title">{t('title.contacts')}</h1>
    <p class="section-subtitle">{t('subtitle.contacts')}</p>
  </div>
</section>

<!-- CONTACTS GRID -->
<section class="section-padding">
  <div class="container contacts-grid">
    
    <!-- Left Column: Info card -->
    <div class="contacts-info-card glass-card">
      <h2 style="color: var(--color-primary); font-size: 1.8rem; margin-bottom: 20px; font-family: var(--font-title);">{t('contacts.details.title')}</h2>
      <p style="color: var(--text-secondary); font-size: 0.95rem;">{t('contacts.details.desc')}</p>
      
      <div class="contacts-info-list">
        <div class="contact-detail-item">
          <div class="contact-detail-icon"><i class="fas fa-map-marker-alt"></i></div>
          <div class="contact-detail-text">
            <h4>{t('contacts.address')}</h4>
            <p id="footer-address-page">г. Кызылорда, ул. Ыбрая Жахаева, 18</p>
          </div>
        </div>
        
        <div class="contact-detail-item">
          <div class="contact-detail-icon"><i class="fas fa-phone-alt"></i></div>
          <div class="contact-detail-text">
            <h4>{t('contacts.phone')}</h4>
            <p><a href="tel:+77242230513" style="color: var(--color-secondary); font-weight: 600;">+7 (7242) 23-05-13</a></p>
          </div>
        </div>

        <div class="contact-detail-item">
          <div class="contact-detail-icon"><i class="fas fa-envelope"></i></div>
          <div class="contact-detail-text">
            <h4>{t('contacts.email')}</h4>
            <p><a href="mailto:kzmedicalcollege@mail.ru" style="color: var(--color-secondary); font-weight: 600;">kzmedicalcollege@mail.ru</a></p>
          </div>
        </div>
      </div>
      
      <hr style="border: 0; border-top: 1px solid var(--border-color); margin: 30px 0;">
      
      <!-- Socials -->
      <div style="display: flex; flex-direction: column; gap: 12px;">
        <h4 style="font-family: var(--font-title); font-size: 1rem;">{lang === 'ru' ? 'Мы в социальных сетях:' : lang === 'kk' ? 'Әлеуметтік желілердегі парақшамыз:' : 'Find us on social networks:'}</h4>
        <div class="social-links">
          <a href="https://www.instagram.com/medcollegekzo/" target="_blank" class="social-link" id="contact-insta" aria-label="Instagram"><i class="fab fa-instagram"></i></a>
          <a href="https://www.facebook.com/profile.php?id=100000861896594" target="_blank" class="social-link" id="contact-facebook" aria-label="Facebook"><i class="fab fa-facebook-f"></i></a>
          <a href="https://www.youtube.com/channel/UCcPSrHk2eqSo0YUAFyDexow" target="_blank" class="social-link" id="contact-youtube" aria-label="YouTube"><i class="fab fa-youtube"></i></a>
        </div>
      </div>
    </div>
    
    <!-- Right Column: Form -->
    <div class="contact-form-card glass-card">
      <h2 style="color: var(--color-primary); font-size: 1.8rem; margin-bottom: 12px; font-family: var(--font-title);">{t('contacts.form.title')}</h2>
      <p style="color: var(--text-secondary); font-size: 0.95rem; margin-bottom: 30px;">{t('contacts.form.desc')}</p>
      
      <form id="contact-form">
        <div class="form-group">
          <label for="cf-name">{t('contacts.label.name')} *</label>
          <input type="text" id="cf-name" class="form-control" required placeholder={lang === 'ru' ? 'Иван Иванов' : lang === 'kk' ? 'Алиби Алиев' : 'John Doe'}>
        </div>
        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 20px; margin-bottom: 20px;">
          <div>
            <label for="cf-email">{t('contacts.label.email')} *</label>
            <input type="email" id="cf-email" class="form-control" required placeholder="example@mail.ru" autocomplete="email">
          </div>
          <div>
            <label for="cf-phone">{t('contacts.label.phone')} *</label>
            <input type="tel" id="cf-phone" class="form-control" required placeholder="+7 (707) 123-45-67">
          </div>
        </div>
        <div class="form-group">
          <label for="cf-subject">{t('contacts.label.subj')}</label>
          <input type="text" id="cf-subject" class="form-control" placeholder={lang === 'ru' ? 'Вопрос по поступлению' : lang === 'kk' ? 'Оқуға түсу туралы сұрақ' : 'Admissions inquiry'}>
        </div>
        <div class="form-group">
          <label for="cf-message">{t('contacts.label.msg')} *</label>
          <textarea id="cf-message" class="form-control" rows="5" required placeholder={lang === 'ru' ? 'Введите ваше сообщение...' : lang === 'kk' ? 'Хабарламаңызды енгізіңіз...' : 'Enter your message...' }></textarea>
        </div>
        <button type="submit" class="btn btn-primary" style="width: 100%;"><i class="far fa-paper-plane"></i> {t('btn.send')}</button>
      </form>
    </div>
  </div>
  
  <!-- Map -->
  <div class="container" style="margin-top: 60px;">
    <h2 style="font-family: var(--font-title); color: var(--color-primary); font-size: 1.8rem; margin-bottom: 24px;">{t('contacts.map.title')}</h2>
    <div class="map-card glass-card">
      <iframe src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d2616.488667554904!2d65.48512211568019!3d44.839841679098495!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x420067fb2f190e8f%3A0xe54ef6e88de879e6!2z0JrRi9C30YvQu9C-0YDQtNC40L3RgdC60LjQuSDQstGL0YHRiNC40Lkg0LzQtdC00LjRhtC80L3RgdC60LjQuSDQutC-0LvQu9C10LTQtiwg0KPRgdGC0LDQvdC-0LLQutCwINC10YHQv9C-0LvQvdC40YLQtdC70Y8!5e0!3m2!1sru!2skz!4v1686762391039!5m2!1sru!2skz" allowfullscreen="" loading="lazy" referrerpolicy="no-referrer-when-downgrade"></iframe>
    </div>
  </div>
</section>
