---
import { useTranslations } from '../i18n/utils';

const { lang } = Astro.props;
const t = useTranslations(lang);
const base = '/kvmk-college';

const getLocalizedUrl = (targetLang: string, page: string) => {
  const prefix = targetLang === 'ru' ? '' : `/${targetLang}`;
  const suffix = page === '/' ? '' : page;
  return `${base}${prefix}${suffix === '' ? '/' : suffix}`;
};
---

<footer>
  <div class="container footer-grid">
    <div class="footer-logo-box">
      <div class="logo-container">
        <img src={`${base}/logo.png`} alt="Логотип КВМК" class="logo-img">
        <div class="logo-text">
          <h2 style="color: var(--color-primary);">КВМК</h2>
          <p>{lang === 'ru' ? 'Высший Медколледж' : lang === 'kk' ? 'Жоғары Медколледж' : 'Higher Medcollege'}</p>
        </div>
      </div>
      <p class="footer-desc">{t('footer.desc')}</p>
      <div class="social-links">
        <a href="https://www.instagram.com/medcollegekzo/" target="_blank" class="social-link" id="footer-insta" aria-label="Instagram"><i class="fab fa-instagram"></i></a>
        <a href="https://www.facebook.com/profile.php?id=100000861896594" target="_blank" class="social-link" id="footer-facebook" aria-label="Facebook"><i class="fab fa-facebook-f"></i></a>
        <a href="https://www.youtube.com/channel/UCcPSrHk2eqSo0YUAFyDexow" target="_blank" class="social-link" id="footer-youtube" aria-label="YouTube"><i class="fab fa-youtube"></i></a>
      </div>
    </div>
    
    <div class="footer-col">
      <h3>{t('footer.links')}</h3>
      <div class="footer-links">
        <a href={getLocalizedUrl(lang, '/')}><i class="fas fa-chevron-right" style="font-size: 0.7rem;"></i> {t('nav.home')}</a>
        <a href={getLocalizedUrl(lang, '/about')}><i class="fas fa-chevron-right" style="font-size: 0.7rem;"></i> {t('nav.about')}</a>
        <a href={getLocalizedUrl(lang, '/specialties')}><i class="fas fa-chevron-right" style="font-size: 0.7rem;"></i> {t('nav.specs')}</a>
        <a href={getLocalizedUrl(lang, '/admissions')}><i class="fas fa-chevron-right" style="font-size: 0.7rem;"></i> {t('nav.admissions')}</a>
        <a href={getLocalizedUrl(lang, '/contacts')}><i class="fas fa-chevron-right" style="font-size: 0.7rem;"></i> {t('nav.contacts')}</a>
      </div>
    </div>
    
    <div class="footer-col">
      <h3>{t('nav.specs')}</h3>
      <div class="footer-links">
        <a href={getLocalizedUrl(lang, '/specialties')}><i class="fas fa-chevron-right" style="font-size: 0.7rem;"></i> {lang === 'ru' ? 'Лечебное дело' : lang === 'kk' ? 'Емдеу ісі' : 'General Medicine'}</a>
        <a href={getLocalizedUrl(lang, '/specialties')}><i class="fas fa-chevron-right" style="font-size: 0.7rem;"></i> {lang === 'ru' ? 'Сестринское дело' : lang === 'kk' ? 'Бикеш ісі' : 'Nursing Care'}</a>
        <a href={getLocalizedUrl(lang, '/specialties')}><i class="fas fa-chevron-right" style="font-size: 0.7rem;"></i> {lang === 'ru' ? 'Фармация' : lang === 'kk' ? 'Фармация' : 'Pharmacy'}</a>
        <a href={getLocalizedUrl(lang, '/specialties')}><i class="fas fa-chevron-right" style="font-size: 0.7rem;"></i> {lang === 'ru' ? 'Стоматология' : lang === 'kk' ? 'Стоматология' : 'Dentistry'}</a>
      </div>
    </div>
    
    <div class="footer-col">
      <h3>{t('footer.contacts')}</h3>
      <div class="footer-contact-info">
        <div class="footer-contact-item">
          <i class="fas fa-map-marker-alt"></i>
          <span id="footer-address">{lang === 'en' ? '18 Ybyray Zhakhayev St, Kyzylorda' : 'г. Кызылорда, ул. Ыбрая Жахаева, 18'}</span>
        </div>
        <div class="footer-contact-item">
          <i class="fas fa-phone-alt"></i>
          <a href="tel:+77242230513" id="footer-phone" style="color: var(--color-secondary); font-weight: 600;">+7 (7242) 23-05-13</a>
        </div>
        <div class="footer-contact-item">
          <i class="fas fa-envelope"></i>
          <a href="mailto:kzmedicalcollege@mail.ru" id="footer-email" style="color: var(--color-secondary); font-weight: 600;">kzmedicalcollege@mail.ru</a>
        </div>
      </div>
    </div>
  </div>
  
  <div class="container footer-bottom">
    <p>&copy; {new Date().getFullYear()} {lang === 'ru' ? 'Кызылординский высший медицинский колледж' : lang === 'kk' ? 'Қызылорда жоғары медициналық колледжі' : 'Kyzylorda Higher Medical College'}. {t('footer.rights')}</p>
  </div>
</footer>
